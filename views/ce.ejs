<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/seo-head') %>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <a href="/" class="corner-btn-left" aria-label="Back to Diary"></a>

  <div class="container ce-page">
    <nav>
      <div class="nav-left">
        <a href="/" class="site-title">company education</a>
        <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
          <svg class="theme-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="6.5" x2="12" y2="3"></line>
            <line x1="17.5" y1="12" x2="21" y2="12"></line>
            <line x1="12" y1="17.5" x2="12" y2="21"></line>
            <line x1="6.5" y1="12" x2="3" y2="12"></line>
            <line x1="16.96" y1="7.04" x2="19.07" y2="4.93"></line>
            <line x1="16.96" y1="16.96" x2="19.07" y2="19.07"></line>
            <line x1="7.04" y1="16.96" x2="4.93" y2="19.07"></line>
            <line x1="7.04" y1="7.04" x2="4.93" y2="4.93"></line>
          </svg>
        </button>
      </div>
    </nav>

    <main class="ce-main">
      <div id="ce-loading" class="ce-loading" aria-live="polite">
        <div class="ce-loading-pulse"></div>
        <p>loading videos…</p>
      </div>

      <div id="ce-categories" class="ce-categories hidden" aria-label="Video categories"></div>

      <div id="ce-empty" class="ce-empty hidden">
        <p>no videos yet.</p>
      </div>

      <div id="ce-error" class="ce-error hidden">
        <p>couldn't load videos. please refresh.</p>
      </div>
    </main>
  </div>

  <script src="/js/main.js"></script>
  <script src="/js/ce.js"></script>
</body>
</html>
