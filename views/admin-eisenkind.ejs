<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('partials/seo-head') %>
  <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png">
  <link rel="icon" href="/favicon-16.png" sizes="16x16" type="image/png">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/eisenkind/css/a4.css">
</head>
<body>
  <a href="/admin" class="corner-btn-left" aria-label="Back to Admin"></a>

  <div class="container">
    <nav>
      <div class="nav-left">
        <span class="site-title">eisenkind</span>
        <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme" type="button">
          <svg class="theme-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="6.5" x2="12" y2="3"></line>
            <line x1="17.5" y1="12" x2="21" y2="12"></line>
            <line x1="12" y1="17.5" x2="12" y2="21"></line>
            <line x1="6.5" y1="12" x2="3" y2="12"></line>
            <line x1="16.96" y1="7.04" x2="19.07" y2="4.93"></line>
            <line x1="16.96" y1="16.96" x2="19.07" y2="19.07"></line>
            <line x1="7.04" y1="16.96" x2="4.93" y2="19.07"></line>
            <line x1="7.04" y1="7.04" x2="4.93" y2="4.93"></line>
          </svg>
        </button>
      </div>
      <div class="nav-right">
        <span id="save-status" class="eisenkind-save-status" aria-live="polite"></span>
      </div>
    </nav>

    <main>
      <div class="new-entry-box">
        <textarea
          id="eisenkind-story-input"
          placeholder="paste or write the story here…"
          spellcheck="true"
          autofocus
        ><%= notes.story %></textarea>
        <button type="button" class="btn" id="save-btn">save</button>
      </div>

      <article class="eisenkind-admin-preview">
        <div id="eisenkind-story-preview" class="eisenkind-story-text"></div>
      </article>
    </main>
  </div>

  <script src="/js/main.js"></script>
  <script src="/js/admin-eisenkind.js"></script>
</body>
</html>
